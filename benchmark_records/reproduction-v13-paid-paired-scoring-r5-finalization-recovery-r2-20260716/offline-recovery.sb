(version 1)
(deny default)
(allow process-fork)
(allow process-exec (literal (param "PYTHON_REAL")))
(allow sysctl-read)
(allow file-read-metadata)
(allow file-read-data
  (literal "/")
  (literal "/dev/fd")
  (subpath "/System")
  (subpath "/usr/lib")
  (subpath (param "PYROOT"))
  (subpath (param "ROOT"))
  (subpath (param "SCRATCH"))
  (subpath (param "OUT")))
(allow file-write*
  (subpath (param "SCRATCH"))
  (subpath (param "OUT")))
(deny network*)
