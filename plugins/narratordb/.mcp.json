{
  "mcpServers": {
    "narratordb": {
      "command": "uvx",
      "args": [
        "--from",
        "narratordb-memory[mcp] @ git+https://github.com/WilliamJnsson/NarratorDB.git@252ae49440e843cd191a6bcd50502e81a7e16465",
        "narratordb-mcp",
        "--init-mode",
        "private",
        "--init-capture-policy",
        "sessions",
        "--client",
        "codex-plugin"
      ],
      "env": {
        "NARRATORDB_LOCAL_ONLY": "1",
        "HF_HUB_OFFLINE": "1",
        "TRANSFORMERS_OFFLINE": "1",
        "DO_NOT_TRACK": "1",
        "NARRATORDB_TELEMETRY": "0"
      }
    }
  }
}
